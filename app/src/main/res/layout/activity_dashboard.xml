<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#0A0A0A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Logo : "F1" rouge + "PREDICT" blanc via SpannableString en Java -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:fontFamily="monospace"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusBarSpacer" />

    <!-- Slider MAP : à droite, séparé du logo, plus court -->
    <LinearLayout
        android:id="@+id/opacityPanel"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvLogo"
        app:layout_constraintBottom_toBottomOf="@+id/tvLogo">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:text="MAP"
            android:textColor="#66FF3030"
            android:textSize="10sp" />

        <SeekBar
            android:id="@+id/opacitySeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="100"
            android:progressTint="#AAFF3030"
            android:thumbTint="#FF3030" />

        <TextView
            android:id="@+id/opacityValue"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="#66FF3030"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:layout_marginStart="6dp"
            android:gravity="end" />

    </LinearLayout>

    <!-- WebView globe -->
    <WebView
        android:id="@+id/globeWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layerType="hardware"
        android:background="#00000000"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@+id/tvLogo"
        app:layout_constraintBottom_toTopOf="@+id/tvSelectRace" />

    <!-- Bouton pause/play rotation — bas droite, au-dessus de tvSelectRace -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnRotate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="Toggle rotation"
        android:src="@drawable/ic_pause"
        app:backgroundTint="#0A0A0A"
        app:borderWidth="0dp"
        app:elevation="4dp"
        app:fabSize="mini"
        app:tint="#FF3030"
        app:rippleColor="#33FF3030"
        app:strokeColor="#55FF3030"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvSelectRace" />

    <!-- Texte central bas -->
    <TextView
        android:id="@+id/tvSelectRace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Select a future race"
        android:fontFamily="monospace"
        android:textSize="20sp"
        android:textColor="#888888"
        app:layout_constraintBottom_toTopOf="@+id/cityCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Carte ville cliquée -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cityCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC001433"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="#557ECFFF"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/red_dot" />

            <TextView
                android:id="@+id/cityNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Paris"
                android:textColor="#7ECFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Barre de navigation custom -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintBottom_toTopOf="@+id/navBarSpacer">

        <!-- Onglet GLOBE -->
        <LinearLayout
            android:id="@+id/tabGlobe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconRaces"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_globe"
                app:tint="#FF3030" />

            <TextView
                android:id="@+id/labelRaces"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="GLOBE"
                android:textColor="#FF3030"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Onglet PREDICT -->
        <LinearLayout
            android:id="@+id/tabPredict"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconPredict"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_lightning"
                app:tint="#888888" />

            <TextView
                android:id="@+id/labelPredict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PREDICT"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Onglet PODIUM -->
        <LinearLayout
            android:id="@+id/tabPodium"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconPodium"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_podium"
                app:tint="#888888" />

            <TextView
                android:id="@+id/labelPodium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PODIUM"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Onglet DRIVER -->
        <LinearLayout
            android:id="@+id/tabDriver"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconDriver"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_driver"
                app:tint="#888888" />

            <TextView
                android:id="@+id/labelDriver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="DRIVER"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/navBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#0A0A0A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>