<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Logo -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:fontFamily="monospace"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="2026 SEASON"
        android:textColor="#444444"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvLogo" />

    <!-- Carte formulaire -->
    <LinearLayout
        android:id="@+id/formCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:background="#141414"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvLogo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <!-- Label email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textColor="#555555"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <!-- Champ email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#2A2A2A"
            app:boxBackgroundColor="#1A1A1A"
            app:hintTextColor="#555555">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="exemple@mail.com"
                android:inputType="textEmailAddress"
                android:textColor="#CCCCCC"
                android:textColorHint="#444444"
                android:fontFamily="monospace"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOT DE PASSE"
            android:textColor="#555555"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <!-- Champ password -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#2A2A2A"
            app:boxBackgroundColor="#1A1A1A"
            app:hintTextColor="#555555"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#555555">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textColor="#CCCCCC"
                android:textColorHint="#444444"
                android:fontFamily="monospace"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Message erreur -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text=""
            android:textColor="#FF3030"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Bouton LOGIN -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SE CONNECTER"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            app:backgroundTint="#FF3030"
            app:cornerRadius="8dp" />

        <!-- Lien vers register -->
        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Pas encore de compte ? S'inscrire"
            android:textColor="#555555"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ProgressBar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#FF3030"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>