<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#0A0A0A"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:text="Profile"
        android:textColor="@color/f1_light_gray"
        android:fontFamily="monospace"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusBarSpacer" />

    <LinearLayout
        android:id="@+id/userCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#1A1A1A"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_driver"
            app:tint="#FF3030"
            android:padding="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textColor="@color/f1_light_gray"
                android:textSize="20sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="user@email.com"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="MEMBER"
                android:textColor="#FF3030"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="#33FF3030"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvHistoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Prediction History"
        android:textColor="#555555"
        android:fontFamily="monospace"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/userCard" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/tvHistoryTitle"
        app:layout_constraintBottom_toTopOf="@+id/btnLogout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="LOG OUT"
        android:textColor="#FF3030"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        app:strokeColor="#44FF3030"
        app:strokeWidth="1dp"
        app:cornerRadius="8dp"
        app:backgroundTint="#00000000"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintBottom_toTopOf="@+id/navBarSpacer">

        <LinearLayout
            android:id="@+id/tabGlobe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconGlobe"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_globe"
                app:tint="#888888" />
            <TextView
                android:id="@+id/labelGlobe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="GLOBE"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabPredict"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconPredict"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_lightning"
                app:tint="#888888" />
            <TextView
                android:id="@+id/labelPredict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PREDICT"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabPodium"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconPodium"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_podium"
                app:tint="@color/gray" />
            <TextView
                android:id="@+id/labelPodium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PODIUM"
                android:textColor="@color/gray"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabDriver"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconDriver"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_driver"
                app:tint="#FF3030" />
            <TextView
                android:id="@+id/labelDriver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="DRIVER"
                android:textColor="#FF3030"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/navBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#0A0A0A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>