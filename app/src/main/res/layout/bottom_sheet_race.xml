<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/bottom_sheet_race.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#141414"
    android:paddingTop="12dp"
    android:paddingBottom="32dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- Poignée -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#333333"
        android:backgroundTint="#333333" />

    <!-- Flag + Nom de la course -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/bsFlag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇦🇺"
            android:textSize="28sp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bsRaceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GP of Australia"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bsCircuit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Albert Park Circuit"
                android:textColor="#555555"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F1F1F"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Infos course : Date / Tours / Distance -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <!-- Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE"
                android:textColor="#444444"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.12" />
            <TextView
                android:id="@+id/bsDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 Mar 2025"
                android:textColor="#CCCCCC"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Divider vertical -->
        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1F1F1F" />

        <!-- Tours -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAISON"
                android:textColor="#444444"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.12" />
            <TextView
                android:id="@+id/bsLaps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025"
                android:textColor="#CCCCCC"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Divider vertical -->
        <View android:layout_width="1dp" android:layout_height="36dp" android:background="#1F1F1F" />

        <!-- Distance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYS"
                android:textColor="#444444"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:letterSpacing="0.12" />
            <TextView
                android:id="@+id/bsDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Australia"
                android:textColor="#CCCCCC"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Label sélecteur pilote -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PREDICT WINNER"
        android:textColor="#444444"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp" />

    <!-- Spinner pilote -->
    <Spinner
        android:id="@+id/bsSpinnerDriver"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/spinner_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="20dp"
        android:popupBackground="#1A1A1A" />

    <!-- Bouton PREDICT -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/bsBtnPredict"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="PREDICT"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:letterSpacing="0.1"
        app:backgroundTint="#FF3030"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_lightning"
        app:iconTint="#FFFFFF"
        app:iconSize="16dp"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

</LinearLayout>